# LiNKbot automation workflow configuration.
# This file is sourced by scripts/workflow/*.sh.

# Core repository/bot settings
BOT_NAME=lisa
BOT_PATH=bots/lisa
MAIN_BRANCH=main

# Upstream fork to import from after you sync it with openclaw/openclaw.
SOURCE_REMOTE_NAME=openclaw-fork
SOURCE_REMOTE_URL=https://github.com/linktrend/openclaw.git
SOURCE_REMOTE_BRANCH=main

# Branch naming
SYNC_BRANCH_PREFIX=automation/openclaw-sync
DEPLOY_BRANCH_PREFIX=automation/linkbot-deploy

# Deployment target used by scripts/deploy-bot.sh
DEPLOY_TARGET=vps

# Validation commands run inside bots/lisa.
# Keep npm-based commands to match the current deployment script conventions.
RUN_INSTALL=1
INSTALL_COMMAND="npm ci"

RUN_BUILD=1
BUILD_COMMAND="npm run build"

RUN_TESTS=1
TEST_COMMAND="npm test"

# Optional command (leave blank to skip)
RUN_EXTRA_CHECKS=0
EXTRA_CHECKS_COMMAND=""

# Automation behavior flags
AUTO_PUSH_BRANCH=1
AUTO_MERGE_TO_MAIN=1
AUTO_PUSH_MAIN=1
AUTO_DEPLOY=1

